# Firebase web SDK config — copy to .env.local and fill in from
# Firebase Console → Project Settings → Your apps → Web app config.
# All keys are exposed to the client (Firebase web SDK config is not secret;
# Firestore security rules are what actually protect data).

VITE_API_KEY=
VITE_AUTH_DOMAIN=
VITE_PROJECT_ID=
VITE_STORAGE_BUCKET=
VITE_MESSAGING_SENDER_ID=
VITE_APP_ID=
VITE_MEASUREMENT_ID=

# Web Push (FCM) public VAPID key — required for push notifications.
# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
# → "Generate key pair" → copy the public key here.
VITE_FIREBASE_VAPID_KEY=

# App Check (optional). Register a reCAPTCHA Enterprise provider in Firebase
# Console → App Check → your web app, and paste the reCAPTCHA Enterprise KEY ID
# here to turn on App Check attestation. Leave blank to disable (no-op without it).
VITE_APPCHECK_SITE_KEY=
# Local dev only: a debug token (App Check → Manage debug tokens) so localhost
# passes attestation. Never set this in production builds.
VITE_APPCHECK_DEBUG_TOKEN=
