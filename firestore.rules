rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ------------------------------------------------------------------
    // NOTE: There is intentionally NO catch-all `match /{document=**}`
    // read rule. Firestore rules are additive (OR), so a wildcard
    // `allow read: if true` would silently override every narrower rule
    // below. Reads are granted per-collection instead.
    //
    // ADMIN GATING: player docs are keyed by player id (e.g. "pShane"),
    // NOT by Firebase Auth uid, so rules cannot look an admin up by path
    // (`get(/players/$(uid))` never resolves). There is therefore no
    // working `isAdmin()` available to security rules. Admin-only writes
    // are enforced server-side in callable Cloud Functions (which query
    // players by `authUid` and check `isAdmin`). To gate *reads* on admin
    // status (e.g. to hide `test` tournaments from the public) you would
    // need a path-addressable admin registry, e.g. `config/admins.uids`,
    // that rules can `get()`. Until that exists, tournaments are public.
    // ------------------------------------------------------------------

    // Tournaments: public read, server-only write.
    // (The previous `test != true || isAdmin()` gate was a no-op: isAdmin()
    // can't resolve in rules — see note above — so it only ever evaluated to
    // `test != true`, and the old `/{document=**}` wildcard made it moot anyway.
    // Kept public to avoid breaking the admin test-tournament listing.)
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if false; // Use Firestore console or seed scripts
    }

    // Players collection: public read (display names are shown app-wide).
    // NOTE: player docs also contain `email`/`authUid`. Firestore read rules
    // are document-level, so public read exposes those fields. If that becomes
    // a concern, move email/authUid to a non-public location (follow-up).
    match /players/{playerId} {
      allow read: if true;
      // Account setup only: an authenticated user may link their own authUid.
      // Updates are restricted to the account-linking fields so a player can
      // NOT escalate privileges by writing `isAdmin` (or editing roster/handicap
      // fields) on their own doc.
      allow update: if request.auth != null
        && (
             (resource.data.authUid == null && request.resource.data.authUid == request.auth.uid)
             || resource.data.authUid == request.auth.uid
           )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['authUid', 'email']);
      allow create, delete: if false;
    }

    // Per-player notification history (players/{id}/notifications/{id}): drives
    // the in-app notification bell + unread badges. Unlike the admin case, the
    // owning playerId is in the PATH, so rules CAN resolve ownership by reading
    // that player doc's authUid. Owner-only read; owner may flip a notification
    // to read (and only the read/readAt fields) or dismiss it from their bell by
    // deleting it. All creates come from the server (notify() via the Admin SDK),
    // which bypasses these rules.
    match /players/{playerId}/notifications/{notifId} {
      function isOwner() {
        return request.auth != null
          && get(/databases/$(database)/documents/players/$(playerId)).data.authUid == request.auth.uid;
      }
      allow read: if isOwner();
      allow update: if isOwner()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);
      allow delete: if isOwner();
      allow create: if false;
    }

    // Matches: public read; rostered players (or an open tournament) may edit
    // ONLY the `holes` map — never status/result/authorizedUids/roster/handicaps.
    // Cloud Functions write those via the Admin SDK, which bypasses these rules.
    match /matches/{matchId} {
      // Check if user is authorized using pre-computed authorizedUids array
      // This avoids expensive player document reads in security rules
      function isAuthorizedPlayer() {
        return request.auth != null &&
               resource.data.keys().hasAny(['authorizedUids']) &&
               request.auth.uid in resource.data.authorizedUids;
      }

      // Allow public edits if the tournament explicitly enables openPublicEdits
      function isTournamentOpen() {
        // Determine tournamentId from existing resource or incoming request without using 'if/else'
        let tid = resource.data.tournamentId != null ? resource.data.tournamentId : (request.resource != null && request.resource.data.tournamentId != null ? request.resource.data.tournamentId : null);
        return tid != null &&
               exists(/databases/$(database)/documents/tournaments/$(tid)) &&
               get(/databases/$(database)/documents/tournaments/$(tid)).data.openPublicEdits == true;
      }

      // Field-level guard: clients may only mutate the `holes` map.
      // The score-entry UI writes `holes.{N}.input`; affectedKeys() reports the
      // top-level key `holes` for nested writes.
      function onlyHolesChanged() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['holes']);
      }

      // Shape guard: `holes` must stay a map, and a write may never DROP an
      // existing hole key. affectedKeys() can't tell a surgical `holes.5.input`
      // update from a full-map replacement, so without this a single client
      // could overwrite `holes` with `{ "5": {...} }` and wipe every other
      // hole's already-entered scores. Per-hole score VALUE validation is left
      // to the server (isValidGross in computeMatchOnWrite) — the nested,
      // format-specific shapes are impractical to validate in rules.
      function holesShapeValid() {
        return request.resource.data.holes is map
          && request.resource.data.holes.keys().hasAll(resource.data.get('holes', {}).keys());
      }

      allow read: if true;
      // `locked != true` enforces the admin per-match lock (set via the
      // setMatchLock callable); undefined/false on existing docs passes.
      allow update: if (isAuthorizedPlayer() || isTournamentOpen())
        && onlyHolesChanged()
        && holesShapeValid()
        && resource.data.get('locked', false) != true;
      allow create, delete: if false;
    }

    // Rounds (+ skinsResults subcollection): public read, server-only write
    match /rounds/{roundId} {
      allow read: if true;
      allow write: if false;
    }
    match /rounds/{roundId}/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Courses: public read, server-only write
    match /courses/{courseId} {
      allow read: if true;
      allow write: if false;
    }

    // Player match facts: public read, server-only write (computed by functions)
    match /playerMatchFacts/{factId} {
      allow read: if true;
      allow write: if false;
    }

    // Aggregated player stats (+ bySeries/byTournament/byRound subcollections):
    // public read, server-only write.
    match /playerStats/{playerId} {
      allow read: if true;
      allow write: if false;
    }
    match /playerStats/{playerId}/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Collection-group read for the `byTournament` stats query used by Teams.tsx
    // (collectionGroup queries require an explicit recursive-wildcard rule).
    match /{path=**}/byTournament/{statId} {
      allow read: if true;
    }

    // Collection-group read for the `bySeries` stats query used by the All-Time
    // leaderboard (useAllTimeLeaderboard). Same as byTournament: collectionGroup
    // queries need their own recursive-wildcard rule; the path-based playerStats
    // rule above only covers direct-path reads. These docs are already public-read.
    match /{path=**}/bySeries/{statId} {
      allow read: if true;
    }

    // Round recaps: public read, server-only write
    match /roundRecaps/{recapId} {
      allow read: if true;
      allow write: if false;
    }

    // Player recent rounds (GHIN last-~20 import): public read, server-only write.
    // Data-only collection consumed by the read-only MCP server so players' AI /
    // captains can assess current off-course form for draft analysis. Public-read
    // (like all app data) so the unauthenticated MCP Web SDK can read it; it is
    // intentionally NOT surfaced anywhere in the app UI. Written by the
    // scripts/import-recent-rounds.js admin script, never by clients.
    match /playerRecentRounds/{playerId} {
      allow read: if true;
      allow write: if false;
    }

    // Sportsbook bets: public read (the marketplace of open offers and the
    // shared who-owes-whom ledger are visible to everyone; bet docs reference
    // only playerIds). All mutations go through the betsOps callables via the
    // Admin SDK — clients never write here directly.
    match /bets/{betId} {
      allow read: if true;
      allow write: if false;
    }

    // Settle-up records (betSettlements/{id}): public read like bets (the
    // who-paid-whom tab is part of the shared ledger). All mutations go through
    // the settlementOps callables via the Admin SDK — clients never write here.
    match /betSettlements/{settlementId} {
      allow read: if true;
      allow write: if false;
    }

    // Comments: public read (match threads + the sportsbook trash-talk feed are
    // visible to everyone). All mutations go through the commentOps callables via
    // the Admin SDK — clients never write here directly. One-level replies live in
    // a `replies` subcollection (also public read, server-only write); subcollection
    // rules are NOT inherited, so it needs its own match block.
    match /comments/{commentId} {
      allow read: if true;
      allow write: if false;
    }
    match /comments/{commentId}/replies/{replyId} {
      allow read: if true;
      allow write: if false;
    }

    // Pairings draft: NOT public — pairings are announced in person, so only
    // the two teams' captains/co-captains and admins may read the live board.
    // Like matches, the authorized auth uids are precomputed into an array on
    // the doc (rules can't resolve captain/admin status by path). All writes
    // go through the draft callables via the Admin SDK.
    match /pairingDrafts/{roundId} {
      function isAuthorized() {
        return request.auth != null &&
               resource.data.keys().hasAny(['authorizedUids']) &&
               request.auth.uid in resource.data.authorizedUids;
      }
      // `resource == null` keeps a not-yet-created draft readable (empty), so
      // admins/captains can tell "no draft yet" apart from "access denied".
      // Once the doc exists, only authorizedUids may read it.
      allow read: if resource == null || isAuthorized();
      allow write: if false;
    }
  }
}
